{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "javaInterfaces": [
    "org.dependencytrack.plugin.api.config.RuntimeConfig"
  ],
  "properties": {
    "enabled": {
      "type": "boolean",
      "title": "Enabled",
      "description": "Whether the Jira notification publisher should be enabled",
      "default": false
    },
    "apiUrl": {
      "type": "string",
      "format": "uri",
      "title": "API URL",
      "minLength": 1
    },
    "username": {
      "type": "string",
      "title": "Username",
      "minLength": 1
    },
    "passwordOrToken": {
      "type": "string",
      "title": "Password or Token",
      "minLength": 1,
      "x-secret-ref": true
    }
  },
  "required": [
    "enabled"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "enabled": {
            "const": true
          }
        }
      },
      "then": {
        "required": [
          "apiUrl",
          "passwordOrToken"
        ]
      }
    }
  ]
}